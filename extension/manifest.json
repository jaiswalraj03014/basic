{
  "manifest_version": 3,
  "name": "SENOVA AI",
  "version": "1.0",
  "description": "A Chrome extension that monitors AI chat interactions to provide mental wellness support and educational reinforcement.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.openai.com/*",
    "*://*.bard.google.com/*",
    "*://*.claude.ai/*",
    "*://*.perplexity.ai/*",
    "*://*.poe.com/*",
    "*://*.chatgpt.com/*",
    "*://*.huggingface.co/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
      }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.openai.com/*",
        "*://openai.com/*",
        "*://*.bard.google.com/*",
        "*://bard.google.com/*",
        "*://*.claude.ai/*",
        "*://claude.ai/*",
        "*://*.perplexity.ai/*",
        "*://perplexity.ai/*",
        "*://*.poe.com/*",
        "*://poe.com/*",
        "*://*.chatgpt.com/*",
        "*://chatgpt.com/*",
        "*://*.huggingface.co/*",
        "*://huggingface.co/*"
      ],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}